<!DOCTYPE html>

<html lang="en">



<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Devyntra - Control Center</title>

    <link rel="stylesheet" href="./dist/tailwind.css">

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="./dist/style.css">

    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

    <style>
        body {

            font-family: 'Inter', sans-serif;

        }



        /* Smooth transitions */

        .action-card {

            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);

        }



        .action-card:hover {

            transform: translateY(-4px);

            box-shadow: 0 12px 24px -8px rgba(0, 0, 0, 0.15);

            border-color: #6366f1;

        }



        .nav-item {

            transition: all 0.15s ease;

            cursor: pointer;

        }



        .nav-item:hover {

            background-color: #f3f4f6;

            color: #111827;

        }



        .nav-item.active {

            background-color: #e0e7ff;

            color: #4338ca;

            font-weight: 500;

        }



        /* Scrollbar styling */

        ::-webkit-scrollbar {

            width: 6px;

        }



        ::-webkit-scrollbar-track {

            background: transparent;

        }



        ::-webkit-scrollbar-thumb {

            background: #e5e7eb;

            border-radius: 3px;

        }



        ::-webkit-scrollbar-thumb:hover {

            background: #d1d5db;

        }



        /* Dark scrollbar for terminal/logs */

        .dark-scrollbar::-webkit-scrollbar {

            width: 6px;

        }



        .dark-scrollbar::-webkit-scrollbar-track {

            background: transparent;

        }



        .dark-scrollbar::-webkit-scrollbar-thumb {

            background: #374151;

            border-radius: 3px;

        }



        .dark-scrollbar::-webkit-scrollbar-thumb:hover {

            background: #4b5563;

        }



        /* Animation for view switching */

        .fade-in {

            animation: fadeIn 0.3s ease-in-out;

        }



        @keyframes fadeIn {

            from {

                opacity: 0;

                transform: translateY(5px);

            }



            to {

                opacity: 1;

                transform: translateY(0);

            }

        }



        .fade-in-up {

            animation: fadeInUp 0.5s ease-out forwards;

        }



        @keyframes fadeInUp {

            from {

                opacity: 0;

                transform: translateY(20px);

            }



            to {

                opacity: 1;

                transform: translateY(0);

            }

        }



        /* Skeleton Loading Animations */

        .skeleton {

            background: linear-gradient(90deg, #f0f0f0 25%, #e5e7eb 50%, #f0f0f0 75%);

            background-size: 200% 100%;

            animation: shimmer 1.5s infinite linear;

        }



        @keyframes shimmer {

            0% {

                background-position: -200% 0;

            }



            100% {

                background-position: 200% 0;

            }

        }



        .skeleton-card {

            background: white;

            border-radius: 1rem;

            border: 1px solid #e5e7eb;

            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);

        }



        /* Hide Scrollbar for Chat */

        #chat-messages {

            scrollbar-width: none;

            /* Firefox */

            -ms-overflow-style: none;

            /* IE/Edge */

        }



        #chat-messages::-webkit-scrollbar {

            display: none;

            /* Chrome/Safari */

        }



        /* Universal Wide Modal System */

        [id$="-modal"]>div,

        #permissions-modal>div,

        #connection-modal>div {

            max-width: 680px !important;

            /* Wider horizontal profile */

            max-height: 95vh !important;

            width: 95% !important;

            padding: 0 !important;

            /* Padding handled by inner containers */

            overflow: hidden !important;

            display: flex !important;

            flex-direction: column !important;

            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;

            border-radius: 1.5rem !important;

        }



        /* Tighten form density globally */

        [id$="-modal"] .space-y-4,

        [id$="-modal"] .space-y-3,

        [id$="-modal"] form {

            gap: 0.75rem !important;

        }



        [id$="-modal"] input,

        [id$="-modal"] select,

        [id$="-modal"] .py-3,

        [id$="-modal"] .py-3\.5 {

            padding-top: 0.6rem !important;

            padding-bottom: 0.6rem !important;

        }



        [id$="-modal"] .mb-6,

        [id$="-modal"] .mb-4 {

            margin-bottom: 0.75rem !important;

        }



        /* High-Density Scaling for shorter screens */

        @media (max-height: 850px) {

            [id$="-modal"]>div {

                transform: scale(0.95);

                transform-origin: center;

            }

        }



        @media (max-height: 750px) {

            [id$="-modal"]>div {

                transform: scale(0.88);

                padding: 1.25rem !important;

            }



            [id$="-modal"] .space-y-4,

            [id$="-modal"] form {

                gap: 0.5rem !important;

            }



            [id$="-modal"] .w-16,

            [id$="-modal"] .h-16 {

                width: 3rem !important;

                height: 3rem !important;

            }



            [id$="-modal"] h2 {

                font-size: 1.15rem !important;

            }

        }



        @media (max-height: 650px) {

            [id$="-modal"]>div {

                transform: scale(0.82);

                padding: 1rem !important;

            }



            [id$="-modal"] p {

                font-size: 11px !important;

                margin-bottom: 0.25rem !important;

            }



            [id$="-modal"] .mt-8,

            [id$="-modal"] .mt-6 {

                margin-top: 0.5rem !important;

            }

        }



        @media (max-height: 550px) {

            [id$="-modal"]>div {

                transform: scale(0.75);

            }



            /* Hide non-critical supplementary text to ensure fit */

            [id$="-modal"] .text-\[10px\],

            [id$="-modal"] .text-\[9px\],

            [id$="-modal"] .mt-1 {

                display: none !important;

            }

        }



        /* Component Library Side Panel */

        .component-library {

            position: fixed;

            right: 0;

            top: 70px;

            bottom: 0;

            width: 280px;

            background: white;

            border-left: 1px solid #e5e7eb;

            box-shadow: -4px 0 15px rgba(0, 0, 0, 0.05);

            transform: translateX(100%);

            /* Hidden by default */

            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);

            z-index: 9999;

            /* Ensure it's on top of everything */

            display: flex;

            flex-direction: column;

        }



        .component-library.open {

            transform: translateX(0);

        }



        .toggle-library-btn {

            position: absolute;

            left: -40px;

            top: 20px;

            width: 40px;

            height: 40px;

            background: white;

            border: 1px solid #e5e7eb;

            border-right: none;

            border-radius: 8px 0 0 8px;

            display: flex;

            align-items: center;

            justify-content: center;

            cursor: pointer;

            box-shadow: -2px 0 5px rgba(0, 0, 0, 0.05);

            transition: all 0.2s;

        }



        .toggle-library-btn:hover {

            width: 45px;

            left: -45px;

            color: #4f46e5;

        }



        .lib-item {

            display: flex;

            align-items: center;

            gap: 12px;

            padding: 12px;

            margin-bottom: 8px;

            background: #f9fafb;

            border: 1px solid #e5e7eb;

            border-radius: 8px;

            cursor: grab;

            transition: all 0.2s;

        }



        .lib-item:hover {

            background: white;

            border-color: #6366f1;

            transform: translateY(-1px);

            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);

        }



        .lib-item:active {

            cursor: grabbing;

        }



        .lib-icon {

            width: 32px;

            height: 32px;

            border-radius: 6px;

            display: flex;

            align-items: center;

            justify-content: center;

        }



        /* Drag Ghost */

        .drag-ghost {

            position: absolute;

            pointer-events: none;

            z-index: 9999;

            opacity: 0.8;

            transform: scale(0.9);

            background: white;

            padding: 10px;

            border-radius: 8px;

            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);

            border: 1px solid #6366f1;

        }



        /* Premium Dashboard Sections */

        .premium-dashboard-card {

            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);

            border: 1px solid rgba(229, 231, 235, 0.4);

            background: rgba(255, 255, 255, 0.8);

            backdrop-filter: blur(20px);

            position: relative;

            box-shadow:

                0 4px 6px -1px rgba(0, 0, 0, 0.05),

                0 2px 4px -1px rgba(0, 0, 0, 0.03),

                0 0 20px -5px rgba(99, 102, 241, 0.05);

            /* Subtle default glow */

        }



        .premium-dashboard-card:hover {

            border-color: rgba(99, 102, 241, 0.3);

            background: rgba(255, 255, 255, 1);

            box-shadow:

                0 25px 50px -12px rgba(0, 0, 0, 0.1),

                0 0 30px -5px rgba(99, 102, 241, 0.25);

            /* Enhanced hover glow */

            transform: translateY(-2px);

            z-index: 5;

        }



        .premium-dashboard-card.pipeline-section:hover {

            border-color: rgba(249, 115, 22, 0.3);

            box-shadow:

                0 25px 50px -12px rgba(0, 0, 0, 0.1),

                0 0 30px -5px rgba(249, 115, 22, 0.25);

            /* Orange hover glow */

        }



        .empty-state-card {

            display: flex;

            flex-direction: column;

            align-items: center;

            justify-content: center;

            text-align: center;

            padding: 2.5rem 1.5rem;

            background: rgba(255, 255, 255, 0.3);

            border: 2px dashed #f3f4f6;

            border-radius: 1.25rem;

            transition: all 0.2s ease;

            width: 100%;

        }



        .empty-state-card:hover {

            border-color: #e5e7eb;

            background: rgba(255, 255, 255, 0.5);

        }



        .empty-state-icon {

            width: 56px;

            height: 56px;

            border-radius: 1rem;

            display: flex;

            align-items: center;

            justify-content: center;

            font-size: 1.25rem;

            margin-bottom: 1rem;

            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);

            transition: all 0.3s ease;

        }



        .empty-state-card:hover .empty-state-icon {

            transform: translateY(-2px);

        }



        /* Skeleton Loading Animations */

        .skeleton {

            background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);

            background-size: 200% 100%;

            animation: shimmer 1.5s infinite;

            border-radius: 8px;

        }



        @keyframes shimmer {

            0% {

                background-position: -200% 0;

            }



            100% {

                background-position: 200% 0;

            }

        }



        .skeleton-text {

            height: 12px;

            margin-bottom: 8px;

            width: 100%;

        }



        .skeleton-title {

            height: 20px;

            margin-bottom: 12px;

            width: 60%;

        }



        .skeleton-avatar {

            width: 48px;

            height: 48px;

            border-radius: 50%;

        }



        .skeleton-card {

            background: white;

            padding: 1.5rem;

            border-radius: 1rem;

            border: 1px solid #e5e7eb;

        }



        /* Global Loader Overlay */

        #global-loader {

            position: fixed;

            inset: 0;

            background: rgba(255, 255, 255, 0.8);

            backdrop-filter: blur(4px);

            z-index: 10000;

            display: flex;

            align-items: center;

            justify-content: center;

            transition: opacity 0.3s ease-out;

        }



        #global-loader.hidden {

            opacity: 0;

            pointer-events: none;

        }



        .loader-content {

            display: flex;

            flex-direction: column;

            align-items: center;

            gap: 1rem;

        }



        .spinner {

            width: 40px;

            height: 40px;

            border: 3px solid #6366f133;

            border-radius: 50%;

            border-top-color: #6366f1;

            animation: spin 0.8s linear infinite;

        }



        @keyframes spin {

            to {

                transform: rotate(360deg);

            }

        }



        /* Connection Handshake Animations */

        @keyframes pulse-ring {

            0% {

                transform: scale(0.33);

            }



            80%,

            100% {

                opacity: 0;

            }

        }



        @keyframes pulse-dot {

            0% {

                transform: scale(0.8);

            }



            50% {

                transform: scale(1);

            }



            100% {

                transform: scale(0.8);

            }

        }



        @keyframes scanning {

            0% {

                transform: translateY(-100%);

                opacity: 0;

            }



            50% {

                opacity: 0.5;

            }



            100% {

                transform: translateY(100%);

                opacity: 0;

            }

        }



        .handshake-orbit {

            animation: rotate 4s linear infinite;

        }



        @keyframes rotate {

            from {

                transform: rotate(0deg);

            }



            to {

                transform: rotate(360deg);

            }

        }



        .signal-wave {

            position: absolute;

            width: 100%;

            height: 100%;

            border: 2px solid currentColor;

            border-radius: 50%;

            opacity: 0;

            animation: wave 2s infinite;

        }



        @keyframes wave {

            0% {

                transform: scale(1);

                opacity: 0.5;

            }



            100% {

                transform: scale(2.5);

                opacity: 0;

            }

        }
    </style>

</head>



<body class="bg-gray-50 text-gray-800 h-screen flex overflow-hidden">

    <!-- Global Loader Overlay -->
    <div id="global-loader" class="flex">

        <div class="loader-content">

            <div class="spinner"></div>

            <div class="text-center">

                <h3 id="loader-title" class="text-lg font-bold text-gray-900">Loading...</h3>

                <p id="loader-desc" class="text-xs text-gray-400">Please wait while we set things up</p>

            </div>

        </div>

    </div>



    <!-- CONNECTION MODAL (Overlay) - Responsive -->

    <div id="connection-modal"
        class="hidden fixed inset-0 bg-gray-900 bg-opacity-75 z-50 flex items-center justify-center backdrop-blur-sm p-4 overflow-hidden">

        <div
            class="bg-white rounded-2xl shadow-2xl p-6 sm:p-8 w-full max-w-md transform transition-all scale-100 relative my-auto">

            <!-- Close Button -->

            <button type="button" onclick="closeConnectionModal()"
                class="absolute top-3 right-3 sm:top-4 sm:right-4 text-gray-400 hover:text-gray-600 w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 transition-colors">

                <i class="fas fa-times"></i>

            </button>



            <!-- Content -->

            <div class="p-8">

                <div class="flex items-center gap-4 mb-6">

                    <div
                        class="w-14 h-14 bg-indigo-100 rounded-2xl flex items-center justify-center text-indigo-600 text-2xl shadow-sm">

                        <i class="fas fa-server"></i>

                    </div>

                    <div class="text-left">

                        <h2 class="text-2xl font-extrabold text-gray-900 leading-tight">Connect to Server</h2>

                        <p class="text-gray-500 text-sm mt-0.5">Use Devyntra Agent (recommended) or SSH credentials.</p>

                    </div>

                </div>



                <div class="mt-2 flex gap-2" id="connection-mode-toggle">

                    <button type="button" id="mode-agent-btn" onclick="setConnectionMode('agent')"
                        class="flex-1 bg-indigo-600 text-white font-bold py-2.5 rounded-xl text-[11px] uppercase tracking-wider shadow-md transition-all">

                        Agent

                    </button>

                    <button type="button" id="mode-user-btn" onclick="setConnectionMode('user')"
                        class="flex-1 bg-gray-100 text-gray-600 font-bold py-2.5 rounded-xl text-[11px] uppercase tracking-wider transition-all">

                        Restricted User

                    </button>

                    <button type="button" id="mode-ssh-btn" onclick="setConnectionMode('ssh')"
                        class="flex-1 bg-gray-100 text-gray-600 font-bold py-2.5 rounded-xl text-[11px] uppercase tracking-wider transition-all">

                        SSH (Root)

                    </button>

                </div>



                <form id="ssh-form" onsubmit="connectToServer(event)">

                    <div class="space-y-4 mt-5">

                        <div>

                            <label
                                class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1.5">Server

                                Identity</label>

                            <input type="text" id="server-name"
                                class="w-full border border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all text-sm"
                                placeholder="e.g. Production Cluster">

                        </div>

                    </div>



                    <div id="agent-mode" class="hidden mt-5">

                        <div class="bg-indigo-50 border border-indigo-100 rounded-2xl p-4">

                            <div class="flex items-start gap-3">

                                <div
                                    class="w-10 h-10 rounded-xl bg-white text-indigo-600 flex items-center justify-center shadow-sm">

                                    <i class="fas fa-plug"></i>

                                </div>

                                <div class="flex-1">

                                    <div class="flex items-center justify-between gap-3">

                                        <h3 class="text-sm font-extrabold text-indigo-900">Install Devyntra Agent</h3>

                                        <button type="button" id="agent-generate-btn" onclick="generateAgentInstall()"
                                            style="box-shadow: 0 0 20px rgba(79, 70, 229, 0.4); border: 2px solid rgba(79, 70, 229, 0.2);"
                                            class="text-[11px] font-black uppercase tracking-wider rounded-xl px-6 py-3 transition-all active:scale-95 bg-indigo-600 text-white hover:bg-indigo-700">

                                            Generate Command

                                        </button>

                                    </div>

                                    <p class="text-xs text-indigo-600 mt-1">Generate a command and run it on your server

                                        (Ubuntu/Linux).</p>

                                    <div id="agent-command-empty" class="mt-3 text-[11px] text-indigo-500 font-medium">

                                        Click "Generate Command" to get your install command.

                                    </div>

                                    <div id="agent-command-box" class="hidden relative mt-3">

                                        <div onclick="copyAgentInstallCommand()"
                                            class="w-full h-24 border rounded-xl px-4 py-3 text-[12px] font-mono text-gray-900 overflow-hidden cursor-pointer select-none transition-all focus:outline-none focus:ring-2 antialiased bg-white border-indigo-100 hover:border-indigo-200 focus:ring-indigo-200/60"
                                            title="Click to copy">

                                            <div id="agent-install-cmd"
                                                class="whitespace-pre-wrap break-all pr-24 leading-relaxed overflow-auto h-full">
                                            </div>

                                            <div id="agent-copy-pill"
                                                class="absolute top-3 right-3 text-[10px] font-bold px-3 py-1.5 rounded-lg border shadow-sm pointer-events-auto transition-colors text-indigo-600 bg-white border-indigo-100 z-10">

                                                Click to copy

                                            </div>

                                        </div>

                                    </div>
                                </div>

                            </div>





                            <div class="flex items-center justify-between mb-5">

                                <div>

                                    <h4 class="text-[10px] font-black text-indigo-600 uppercase tracking-[0.2em]">Step 2

                                        : System Link</h4>

                                    <p class="text-[11px] text-gray-500 mt-1 font-semibold">Initializing secure

                                        handshake protocol...</p>

                                </div>

                                <div
                                    class="px-2.5 py-1 bg-indigo-50 rounded-lg border border-indigo-100 flex items-center gap-1.5">

                                    <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>

                                    <span
                                        class="text-[9px] font-black text-indigo-600 uppercase tracking-tight">Realtime

                                        Sync</span>

                                </div>

                            </div>



                            <div
                                class="flex items-center gap-6 p-5 bg-gray-50/80 rounded-2xl border border-gray-100 transition-all group-hover/agent:border-indigo-200 group-hover/agent:bg-white group-hover/agent:shadow-lg group-hover/agent:shadow-indigo-500/5">

                                <!-- Enhanced Sharp Animation Container -->

                                <div
                                    class="relative flex items-center justify-center w-14 h-14 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-visible">

                                    <!-- Orbiting elements - Thinner and sharper -->

                                    <div
                                        class="handshake-orbit absolute inset-0 rounded-full border border-indigo-200/50 scale-125">

                                    </div>



                                    <!-- Signal Waves - Sharper borders -->

                                    <div class="signal-wave text-indigo-500/20" style="border-width: 1px;"></div>

                                    <div class="signal-wave text-indigo-500/10"
                                        style="animation-delay: 0.7s; border-width: 1px;"></div>

                                    <div class="signal-wave text-indigo-500/5"
                                        style="animation-delay: 1.4s; border-width: 1px;"></div>



                                    <!-- Core Dot - High Contrast -->

                                    <div id="agent-status-dot"
                                        class="relative z-10 w-4 h-4 rounded-full bg-indigo-600 shadow-[0_0_15px_rgba(79,70,229,0.5)] border-2 border-white transition-all duration-500 ease-in-out">

                                    </div>

                                </div>



                                <div class="flex flex-col flex-1">

                                    <div class="flex items-center gap-3">

                                        <span id="agent-status-text"
                                            class="text-[15px] font-black text-gray-900 tracking-tight">Awaiting

                                            Handshake</span>

                                        <div class="flex gap-1">

                                            <div
                                                class="w-1 h-1 bg-indigo-600 rounded-full animate-bounce [animation-delay:-0.3s]">

                                            </div>

                                            <div
                                                class="w-1 h-1 bg-indigo-600 rounded-full animate-bounce [animation-delay:-0.15s]">

                                            </div>

                                            <div class="w-1 h-1 bg-indigo-600 rounded-full animate-bounce"></div>

                                        </div>

                                    </div>

                                    <div class="flex items-center gap-2 mt-1.5">

                                        <div
                                            class="px-1.5 py-0.5 bg-gray-200/50 rounded text-[9px] font-bold text-gray-500 uppercase tracking-widest flex items-center gap-1">

                                            <i class="fas fa-satellite-dish text-[8px]"></i>

                                            <span>Searching</span>

                                        </div>

                                        <span
                                            class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Secure

                                            Verification Active</span>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>



                    <div id="ssh-mode" class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-5 mt-5">

                        <!-- Left Column -->

                        <div class="space-y-5">

                            <div>

                                <label
                                    class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1.5">Network

                                    Address</label>

                                <input type="text" id="host"
                                    class="w-full border border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all font-mono text-sm"
                                    placeholder="192.168.1.100" required>

                            </div>



                            <div>

                                <label
                                    class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1.5">Access

                                    Username</label>

                                <div class="relative">

                                    <span
                                        class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400 pointer-events-none"><i
                                            class="fas fa-user-shield text-xs"></i></span>

                                    <input type="text" id="username"
                                        class="w-full border border-gray-200 rounded-xl pl-11 pr-4 py-3 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all font-mono text-sm"
                                        placeholder="root" value="root" required>

                                </div>

                            </div>

                        </div>



                        <!-- Right Column -->

                        <div class="space-y-5">

                            <div>

                                <label
                                    class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1.5">Authentication

                                    Method (Key)</label>

                                <div class="relative">

                                    <input type="file" id="keyfile" class="hidden"
                                        onchange="document.getElementById('key-display').value = this.files[0]?.path || ''">

                                    <div class="flex gap-2">

                                        <input type="text" id="key-display"
                                            class="w-full border border-gray-200 rounded-xl px-4 py-3 bg-gray-50 text-gray-500 text-sm cursor-pointer"
                                            placeholder="Select .pem / .ppk" readonly
                                            onclick="document.getElementById('keyfile').click()">

                                        <button type="button" onclick="document.getElementById('keyfile').click()"
                                            class="bg-indigo-50 hover:bg-indigo-100 text-indigo-600 rounded-xl px-4 transition-colors border border-indigo-100"><i
                                                class="fas fa-folder-open"></i></button>

                                    </div>

                                </div>

                            </div>



                            <div>

                                <label
                                    class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1.5">Alternative

                                    Password</label>

                                <div class="relative">

                                    <span
                                        class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400 pointer-events-none"><i
                                            class="fas fa-lock text-xs"></i></span>

                                    <input type="password" id="password"
                                        class="w-full border border-gray-200 rounded-xl pl-11 pr-4 py-3 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all text-sm"
                                        placeholder="Enter password (if no key)">

                                </div>

                            </div>



                            <div class="pt-2 space-y-3">

                                <label class="flex items-center gap-3 cursor-pointer group">

                                    <input type="checkbox" id="is-elastic-ip"
                                        class="w-5 h-5 text-indigo-600 rounded-lg border-gray-300 focus:ring-indigo-500/20 transition-all">

                                    <span
                                        class="text-xs text-gray-600 font-medium group-hover:text-indigo-600 transition-colors">Confirm

                                        Static IP Address</span>

                                </label>

                                <label class="flex items-center gap-3 cursor-pointer group">

                                    <input type="checkbox" id="save-key-pair"
                                        class="w-5 h-5 text-indigo-600 rounded-lg border-gray-300 focus:ring-indigo-500/20 transition-all">

                                    <div class="flex flex-col">

                                        <span
                                            class="text-xs text-gray-600 font-medium group-hover:text-indigo-600 transition-colors">Save

                                            Keypair to Cloud</span>

                                        <span
                                            class="text-[9px] text-orange-500 font-bold uppercase tracking-tight">Encrypted

                                            Storage</span>

                                    </div>

                                </label>

                            </div>

                        </div>

                    </div>



                    <div class="mt-8 flex gap-4">

                        <button type="button" onclick="closeConnectionModal()"
                            class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-4 rounded-xl transition-all active:scale-95">

                            Cancel

                        </button>



                        <button type="submit" id="connect-btn"
                            class="flex-[2] bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-4 rounded-xl shadow-xl shadow-indigo-100 transition-all transform active:scale-95">

                            <span>Connect Securely</span>

                            <i class="fas fa-shield-alt ml-2"></i>

                        </button>

                    </div>



                    <div id="conn-error"
                        class="hidden p-3 bg-red-50 text-red-600 text-sm rounded-lg text-center border border-red-100 mt-4">

                    </div>

                </form>

            </div>

        </div>

    </div>









    <!-- DRAG & DROP OVERLAY -->

    <div id="drag-overlay"
        class="hidden fixed inset-0 bg-indigo-900/90 z-[90] flex flex-col items-center justify-center backdrop-blur-md transition-all pointer-events-none">

        <div
            class="bg-white/10 p-10 rounded-3xl border-4 border-dashed border-white/30 backdrop-blur-xl flex flex-col items-center animate-bounce-slight">

            <i class="fas fa-cloud-upload-alt text-white text-7xl mb-6 shadow-glow"></i>

            <h2 class="text-3xl font-bold text-white mb-2">Drop Files to Upload</h2>

            <p class="text-indigo-200 text-lg">Uploading to: <span id="drag-target-path"
