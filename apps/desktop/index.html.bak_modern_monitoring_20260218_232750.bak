    <!-- SETTINGS MODAL -->

    <div id="settings-modal"
        class="hidden fixed inset-0 bg-gray-900/50 z-[60] flex items-center justify-center backdrop-blur-sm fade-in">

        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden transform scale-100 transition-all">

            <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">

                <h3 class="text-lg font-bold text-gray-800">Account Settings</h3>

                <button onclick="document.getElementById('settings-modal').classList.add('hidden')"
                    class="text-gray-400 hover:text-gray-600 transition-colors">

                    <i class="fas fa-times"></i>

                </button>

            </div>



            <div class="p-8">

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                    <!-- Avatar Section -->

                    <div
                        class="flex flex-col items-center justify-center p-6 bg-gray-50 rounded-2xl border border-gray-100">

                        <img id="settings-avatar" src=""
                            class="w-32 h-32 rounded-full border-4 border-white shadow-xl object-cover mb-4">

                        <input type="file" id="avatar-upload" class="hidden" accept="image/*"
                            onchange="uploadAvatar(this)">

                        <button onclick="document.getElementById('avatar-upload').click()"
                            class="bg-white text-indigo-600 px-4 py-2 rounded-xl text-xs font-bold border border-indigo-100 hover:bg-indigo-50 transition-all">Change

                            Profile Picture</button>

                        <p class="text-[10px] text-gray-400 mt-2">Supports JPG, PNG (Max 2MB)</p>

                    </div>



                    <!-- Details Section -->

                    <div class="space-y-6">

                        <div>

                            <label
                                class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-2">Display

                                Name</label>

                            <div class="relative">

                                <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400"><i
                                        class="fas fa-user text-xs"></i></span>

                                <input type="text" id="settings-name-input"
                                    class="w-full border border-gray-200 rounded-xl pl-11 pr-4 py-3 text-sm focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all bg-gray-50 focus:bg-white"
                                    placeholder="Your Full Name">

                            </div>

                        </div>



                        <div>

                            <label
                                class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-2">Registered

                                Email</label>

                            <div class="relative">

                                <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400"><i
                                        class="fas fa-envelope text-xs"></i></span>

                                <input type="email" id="settings-email-input" readonly
                                    class="w-full border border-gray-100 bg-gray-100 rounded-xl pl-11 pr-4 py-3 text-sm text-gray-500 cursor-not-allowed">

                            </div>

                            <p class="text-[9px] text-gray-400 mt-1.5 ml-1">Account email is managed by your provider.

                            </p>

                        </div>



                        <div>

                            <label
                                class="block text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-2">Download

                                Folder</label>

                            <div class="flex gap-2">

                                <input type="text" id="settings-download-path" readonly
                                    class="flex-1 border border-gray-100 bg-gray-100 rounded-xl px-4 py-3 text-sm text-gray-500 cursor-not-allowed"
                                    placeholder="Choose a folder">

                                <button onclick="changeDownloadFolder()"
                                    class="px-4 py-3 bg-white border border-gray-200 text-gray-700 rounded-xl text-xs font-bold hover:bg-gray-50 transition-all">Change</button>

                            </div>

                            <p class="text-[9px] text-gray-400 mt-1.5 ml-1">Files will download here by default.</p>

                        </div>

                    </div>

                </div>



                <div class="mt-10 flex justify-end gap-3 p-1">

                    <button onclick="document.getElementById('settings-modal').classList.add('hidden')"
                        class="px-6 py-3 text-sm font-bold text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-xl transition-all">Discard</button>

                    <button onclick="saveUserProfile()" id="btn-save-profile"
                        class="px-10 py-3 text-sm font-bold text-white bg-indigo-600 hover:bg-indigo-700 rounded-xl shadow-lg shadow-indigo-100 transition-all active:scale-95">

                        Save Preferences

                    </button>

                </div>

            </div>

        </div>

    </div>



    <!-- CREATE USER MODAL -->

    <div id="create-user-modal"
        class="hidden fixed inset-0 bg-gray-900/50 z-[70] flex items-center justify-center backdrop-blur-sm fade-in">

        <div class="bg-white rounded-2xl shadow-2xl w-full">

            <div class="px-8 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">

                <div class="flex items-center gap-3">

                    <div class="w-10 h-10 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">

                        <i class="fas fa-user-plus"></i>

                    </div>

                    <h3 class="text-xl font-extrabold text-gray-900">Create New User</h3>

                </div>

                <button onclick="document.getElementById('create-user-modal').classList.add('hidden')"
                    class="text-gray-400 hover:text-gray-600 transition-colors"><i class="fas fa-times"></i></button>

            </div>

            <div class="p-8">

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    <div class="space-y-5">

                        <div>

                            <label
                                class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">Username</label>

                            <input type="text" id="new-user-name"
                                class="w-full border border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 outline-none transition-all text-sm"
                                placeholder="john_doe">

                        </div>

                        <div>

                            <label
                                class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">Secure

                                Password</label>

                            <input type="password" id="new-user-pass"
                                class="w-full border border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 outline-none transition-all text-sm"
                                placeholder="">

                        </div>

                    </div>

                    <div class="space-y-5">

                        <div>

                            <label
                                class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">Assigned

                                Groups</label>

                            <input type="text" id="new-user-groups" placeholder="sudo, docker, dev"
                                class="w-full border border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 outline-none transition-all text-sm">

                            <p class="text-[10px] text-gray-400 mt-2">Comma-separated list of system groups.</p>

                        </div>

                    </div>

                </div>

                <div class="pt-8 flex gap-3">

                    <button onclick="document.getElementById('create-user-modal').classList.add('hidden')"
                        class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 py-3.5 rounded-xl font-bold transition-all">Cancel</button>

                    <button onclick="submitCreateUser()"
                        class="flex-[2] bg-indigo-600 hover:bg-indigo-700 text-white py-3.5 rounded-xl font-bold shadow-lg shadow-indigo-100 transition-all active:scale-95">Establish

                        User Account</button>

                </div>

            </div>

        </div>

    </div>



    <!-- Edit User Modal -->

    <div id="edit-user-modal"
        class="hidden fixed inset-0 bg-gray-900/50 z-[75] flex items-center justify-center backdrop-blur-sm fade-in">

        <div class="bg-white rounded-2xl shadow-2xl w-full">

            <div class="px-8 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">

                <div class="flex items-center gap-3">

                    <div class="w-10 h-10 bg-amber-100 rounded-xl flex items-center justify-center text-amber-600">

                        <i class="fas fa-user-edit"></i>

                    </div>

                    <h3 class="text-xl font-extrabold text-gray-900">Manage Account: <span id="edit-user-name-title"
                            class="text-indigo-600"></span></h3>

                </div>

                <button onclick="document.getElementById('edit-user-modal').classList.add('hidden')"
                    class="text-gray-400 hover:text-gray-600 transition-colors"><i class="fas fa-times"></i></button>

            </div>

            <div class="p-8">

                <input type="hidden" id="edit-user-name">

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                    <div class="space-y-5">

                        <div>

                            <label
