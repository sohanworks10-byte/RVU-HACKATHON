                                    <th class="px-4 py-3 font-medium text-gray-500">Size</th>

                                    <th class="px-4 py-3 font-medium text-gray-500">Modified</th>

                                </tr>

                            </thead>

                            <tbody class="divide-y divide-gray-100" id="files-table-body">

                                ${getSkeletonHtml('table-rows')}

                            </tbody>

                        </table>

                    </div>

