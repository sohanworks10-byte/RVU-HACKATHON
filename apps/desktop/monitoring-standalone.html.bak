<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Devyntra Monitoring - Server Analytics</title>
    <link rel="stylesheet" href="./dist/tailwind.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background: #f1f5f9;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(226, 232, 240, 0.8);
            border-radius: 24px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        }
        .metric-value {
            font-variant-numeric: tabular-nums;
        }
        .pulse-dot {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        .connection-status {
            position: fixed;
            top: 16px;
            right: 16px;
            z-index: 50;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: white;
            border-radius: 9999px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            font-size: 12px;
            font-weight: 600;
        }
        .status-online {
            color: #10b981;
        }
        .status-offline {
            color: #ef4444;
        }
        .chart-container {
            position: relative;
            height: 120px;
            width: 100%;
        }
        /* Loading shimmer effect */
        .shimmer {
            background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
        }
        @keyframes shimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
    </style>
</head>
<body class="min-h-screen">
    <!-- Connection Status Indicator -->
    <div id="connection-status" class="connection-status">
        <span id="status-dot" class="w-2 h-2 rounded-full bg-gray-400 pulse-dot"></span>
        <span id="status-text">Connecting...</span>
    </div>

    <!-- Header -->
    <header class="bg-white border-b border-slate-200 px-6 py-4 sticky top-0 z-40">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gradient-to-br from-slate-900 to-slate-700 rounded-xl flex items-center justify-center text-white">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div>
                    <h1 class="text-lg font-bold text-slate-900">Server Monitoring</h1>
                    <p class="text-xs text-slate-500">Real-time system analytics</p>
                </div>
            </div>
            <div class="flex items-center gap-4">
                <div class="text-right">
                    <p class="text-xs text-slate-400 uppercase tracking-wider">Backend</p>
                    <p class="text-xs font-medium text-slate-600" id="backend-url">Loading...</p>
                </div>
                <button onclick="refreshAllStats()" class="p-2 hover:bg-slate-100 rounded-lg transition-colors" title="Refresh">
                    <i class="fas fa-sync-alt text-slate-600"></i>
                </button>
                <button onclick="toggleAlwaysOnTop()" class="p-2 hover:bg-slate-100 rounded-lg transition-colors" title="Toggle Always on Top">
                    <i class="fas fa-thumbtack text-slate-600" id="pin-icon"></i>
                </button>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="p-6">
        <!-- Server Selector -->
        <div class="mb-6 flex items-center gap-4">
            <label class="text-sm font-medium text-slate-700">Connected Server:</label>
            <select id="server-select" class="px-4 py-2 bg-white border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                <option value="">No server connected</option>
            </select>
            <span id="last-update" class="text-xs text-slate-400 ml-auto">Last updated: Never</span>
        </div>

        <!-- Metrics Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- CPU Card -->
            <div class="glass-card p-6">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center text-white">
                            <i class="fas fa-microchip"></i>
                        </div>
                        <div>
                            <h3 class="text-sm font-semibold text-slate-900">CPU Usage</h3>
                            <p class="text-xs text-slate-500">Processor utilization</p>
                        </div>
                    </div>
                    <span class="text-2xl font-bold text-slate-900 metric-value" id="cpu-percent">--%</span>
                </div>
                <div class="chart-container">
                    <canvas id="cpu-chart"></canvas>
                </div>
                <div class="grid grid-cols-3 gap-2 mt-4 text-center">
                    <div class="bg-slate-50 rounded-lg p-2">
                        <p class="text-xs text-slate-500">User</p>
                        <p class="text-sm font-semibold text-slate-900" id="cpu-user">--%</p>
                    </div>
                    <div class="bg-slate-50 rounded-lg p-2">
                        <p class="text-xs text-slate-500">System</p>
                        <p class="text-sm font-semibold text-slate-900" id="cpu-system">--%</p>
                    </div>
                    <div class="bg-slate-50 rounded-lg p-2">
                        <p class="text-xs text-slate-500">IO Wait</p>
                        <p class="text-sm font-semibold text-slate-900" id="cpu-iowait">--%</p>
                    </div>
                </div>
            </div>

            <!-- Memory Card -->
            <div class="glass-card p-6">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl flex items-center justify-center text-white">
                            <i class="fas fa-memory"></i>
                        </div>
                        <div>
                            <h3 class="text-sm font-semibold text-slate-900">Memory</h3>
                            <p class="text-xs text-slate-500">RAM utilization</p>
                        </div>
                    </div>
                    <span class="text-2xl font-bold text-slate-900 metric-value" id="memory-percent">--%</span>
                </div>
                <div class="chart-container">
                    <canvas id="memory-chart"></canvas>
                </div>
                <div class="grid grid-cols-2 gap-2 mt-4 text-center">
                    <div class="bg-slate-50 rounded-lg p-2">
                        <p class="text-xs text-slate-500">Used</p>
                        <p class="text-sm font-semibold text-slate-900" id="memory-used">-- GB</p>
                    </div>
                    <div class="bg-slate-50 rounded-lg p-2">
                        <p class="text-xs text-slate-500">Total</p>
                        <p class="text-sm font-semibold text-slate-900" id="memory-total">-- GB</p>
                    </div>
                </div>
            </div>

            <!-- Disk Card -->
            <div class="glass-card p-6">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-gradient-to-br from-amber-500 to-orange-500 rounded-xl flex items-center justify-center text-white">
                            <i class="fas fa-hdd"></i>
                        </div>
                        <div>
                            <h3 class="text-sm font-semibold text-slate-900">Disk</h3>
                            <p class="text-xs text-slate-500">Storage usage</p>
                        </div>
                    </div>
                    <span class="text-2xl font-bold text-slate-900 metric-value" id="disk-percent">--%</span>
                </div>
                <div class="chart-container">
                    <canvas id="disk-chart"></canvas>
                </div>
                <div class="grid grid-cols-2 gap-2 mt-4 text-center">
                    <div class="bg-slate-50 rounded-lg p-2">
                        <p class="text-xs text-slate-500">Used</p>
                        <p class="text-sm font-semibold text-slate-900" id="disk-used">-- GB</p>
                    </div>
                    <div class="bg-slate-50 rounded-lg p-2">
                        <p class="text-xs text-slate-500">Total</p>
                        <p class="text-sm font-semibold text-slate-900" id="disk-total">-- GB</p>
                    </div>
                </div>
            </div>

            <!-- Network Card -->
            <div class="glass-card p-6">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-xl flex items-center justify-center text-white">
                            <i class="fas fa-network-wired"></i>
                        </div>
                        <div>
                            <h3 class="text-sm font-semibold text-slate-900">Network</h3>
                            <p class="text-xs text-slate-500">I/O statistics</p>
                        </div>
                    </div>
                </div>
                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-slate-600"><i class="fas fa-arrow-down text-emerald-500 mr-2"></i>Download</span>
                        <span class="text-sm font-semibold text-slate-900" id="net-download">-- MB/s</span>
                    </div>
                    <div class="w-full bg-slate-100 rounded-full h-2">
                        <div id="net-download-bar" class="bg-emerald-500 h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-slate-600"><i class="fas fa-arrow-up text-blue-500 mr-2"></i>Upload</span>
                        <span class="text-sm font-semibold text-slate-900" id="net-upload">-- MB/s</span>
                    </div>
                    <div class="w-full bg-slate-100 rounded-full h-2">
                        <div id="net-upload-bar" class="bg-blue-500 h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
                    </div>
                </div>
            </div>

            <!-- Uptime Card -->
            <div class="glass-card p-6">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-gradient-to-br from-rose-500 to-pink-500 rounded-xl flex items-center justify-center text-white">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div>
                            <h3 class="text-sm font-semibold text-slate-900">Uptime</h3>
                            <p class="text-xs text-slate-500">System availability</p>
                        </div>
                    </div>
                </div>
                <div class="text-center py-4">
                    <p class="text-3xl font-bold text-slate-900 metric-value" id="uptime-value">--</p>
                    <p class="text-xs text-slate-500 mt-1">Days running</p>
                </div>
                <div class="grid grid-cols-3 gap-2 mt-4 text-center">
                    <div class="bg-slate-50 rounded-lg p-2">
                        <p class="text-xs text-slate-500">Load 1m</p>
                        <p class="text-sm font-semibold text-slate-900" id="load-1">--</p>
                    </div>
                    <div class="bg-slate-50 rounded-lg p-2">
                        <p class="text-xs text-slate-500">Load 5m</p>
                        <p class="text-sm font-semibold text-slate-900" id="load-5">--</p>
                    </div>
                    <div class="bg-slate-50 rounded-lg p-2">
                        <p class="text-xs text-slate-500">Load 15m</p>
                        <p class="text-sm font-semibold text-slate-900" id="load-15">--</p>
                    </div>
                </div>
            </div>

            <!-- Top Processes -->
            <div class="glass-card p-6">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-gradient-to-br from-indigo-500 to-violet-500 rounded-xl flex items-center justify-center text-white">
                            <i class="fas fa-terminal"></i>
                        </div>
                        <div>
                            <h3 class="text-sm font-semibold text-slate-900">Top Processes</h3>
                            <p class="text-xs text-slate-500">CPU consumers</p>
                        </div>
                    </div>
                </div>
                <div class="overflow-y-auto max-h-40" id="process-list">
                    <p class="text-sm text-slate-400 text-center py-8">No data available</p>
                </div>
            </div>
        </div>
    </main>

    <script>
        // Global state
        let backendUrl = '';
        let currentServerId = '';
        let updateInterval = null;
        let charts = {};
        let isAlwaysOnTop = false;

        // Data history for charts
        const maxDataPoints = 20;
        const chartData = {
            cpu: Array(maxDataPoints).fill(0),
            memory: Array(maxDataPoints).fill(0),
            disk: Array(maxDataPoints).fill(0)
        };

        // Initialize
        async function init() {
            try {
                // Get backend URL from main process
                const result = await window.electronAPI.getBackendUrl();
                if (result.success) {
                    backendUrl = result.url;
                    document.getElementById('backend-url').textContent = backendUrl;
                    updateConnectionStatus('online');
                }

                // Initialize charts
                initCharts();

                // Start polling
                startPolling();

                // Load initial data
                await refreshAllStats();

            } catch (error) {
                console.error('Initialization error:', error);
                updateConnectionStatus('offline');
            }
        }

        // Initialize Chart.js charts
        function initCharts() {
            const commonOptions = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { display: false },
                    y: { display: false, min: 0, max: 100 }
                },
                elements: {
                    point: { radius: 0 },
                    line: { tension: 0.4, borderWidth: 2 }
                }
            };

            charts.cpu = new Chart(document.getElementById('cpu-chart'), {
                type: 'line',
                data: {
                    labels: Array(maxDataPoints).fill(''),
                    datasets: [{
                        data: chartData.cpu,
                        borderColor: '#3b82f6',
                        backgroundColor: 'rgba(59, 130, 246, 0.1)',
                        fill: true
                    }]
                },
                options: commonOptions
            });

            charts.memory = new Chart(document.getElementById('memory-chart'), {
                type: 'line',
                data: {
                    labels: Array(maxDataPoints).fill(''),
                    datasets: [{
                        data: chartData.memory,
                        borderColor: '#8b5cf6',
                        backgroundColor: 'rgba(139, 92, 246, 0.1)',
                        fill: true
                    }]
                },
                options: commonOptions
            });

            charts.disk = new Chart(document.getElementById('disk-chart'), {
                type: 'line',
                data: {
                    labels: Array(maxDataPoints).fill(''),
                    datasets: [{
                        data: chartData.disk,
                        borderColor: '#f59e0b',
                        backgroundColor: 'rgba(245, 158, 11, 0.1)',
                        fill: true
                    }]
                },
                options: commonOptions
            });
        }

        // Update connection status UI
        function updateConnectionStatus(status) {
            const dot = document.getElementById('status-dot');
            const text = document.getElementById('status-text');
            
            if (status === 'online') {
                dot.className = 'w-2 h-2 rounded-full bg-emerald-500 pulse-dot';
                text.textContent = 'Connected';
                text.className = 'status-online font-medium';
            } else {
                dot.className = 'w-2 h-2 rounded-full bg-red-500';
                text.textContent = 'Disconnected';
                text.className = 'status-offline font-medium';
            }
        }

        // Start polling for updates
        function startPolling() {
            // Update every 3 seconds
            updateInterval = setInterval(refreshAllStats, 3000);
        }

        // Refresh all statistics
        async function refreshAllStats() {
            try {
                if (!currentServerId) {
                    // Try to get from storage or wait for connection
                    return;
                }

                const response = await fetch(`${backendUrl}/ssh/stats`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${window.electronAPI.getToken()}`
                    },
                    body: JSON.stringify({ serverId: currentServerId })
                });

                if (!response.ok) throw new Error('Failed to fetch stats');

                const data = await response.json();
                if (data.success && data.data) {
                    updateMetrics(data.data);
                    updateConnectionStatus('online');
                }

                document.getElementById('last-update').textContent = 
                    'Last updated: ' + new Date().toLocaleTimeString();

            } catch (error) {
                console.error('Refresh error:', error);
                updateConnectionStatus('offline');
            }
        }

        // Update UI with new metrics
        function updateMetrics(data) {
            // CPU
            const cpuTotal = parseFloat(data.cpu) || 0;
            document.getElementById('cpu-percent').textContent = cpuTotal.toFixed(1) + '%';
            document.getElementById('cpu-user').textContent = (parseFloat(data.cpu_user) || 0).toFixed(1) + '%';
            document.getElementById('cpu-system').textContent = (parseFloat(data.cpu_sys) || 0).toFixed(1) + '%';
            document.getElementById('cpu-iowait').textContent = (parseFloat(data.cpu_wait) || 0).toFixed(1) + '%';
            
            chartData.cpu.shift();
            chartData.cpu.push(cpuTotal);
            charts.cpu.update('none');

            // Memory
            const memPercent = parseFloat(data.ram) || 0;
            document.getElementById('memory-percent').textContent = memPercent.toFixed(1) + '%';
            
            chartData.memory.shift();
            chartData.memory.push(memPercent);
            charts.memory.update('none');

            // Disk
            const diskPercent = parseFloat(data.disk) || 0;
            document.getElementById('disk-percent').textContent = diskPercent + '%';
            
            chartData.disk.shift();
            chartData.disk.push(diskPercent);
            charts.disk.update('none');

            // Uptime and load
            if (data.uptime) {
                const uptimeMatch = data.uptime.match(/(\d+)\s*day/);
                document.getElementById('uptime-value').textContent = uptimeMatch ? uptimeMatch[1] : '0';
            }

            // Network (placeholder - would need actual network data)
            const netIn = Math.random() * 10; // Placeholder
            const netOut = Math.random() * 5;
            document.getElementById('net-download').textContent = netIn.toFixed(1) + ' MB/s';
            document.getElementById('net-upload').textContent = netOut.toFixed(1) + ' MB/s';
            document.getElementById('net-download-bar').style.width = Math.min(netIn * 10, 100) + '%';
            document.getElementById('net-upload-bar').style.width = Math.min(netOut * 10, 100) + '%';

            // Top processes (placeholder)
            updateProcessList(data);
        }

        // Update process list
        function updateProcessList(data) {
            if (data.topCpu) {
                const processes = data.topCpu.split('\n').slice(0, 5);
                const html = processes.map(proc => {
                    const parts = proc.trim().split(/\s+/);
                    if (parts.length > 10) {
                        const cpu = parts[2];
                        const name = parts[parts.length - 1];
                        return `<div class="flex justify-between items-center py-1 border-b border-slate-100 last:border-0">
                            <span class="text-xs text-slate-600 truncate max-w-[150px]">${name}</span>
                            <span class="text-xs font-semibold text-slate-900">${cpu}%</span>
                        </div>`;
                    }
                    return '';
                }).join('');
                document.getElementById('process-list').innerHTML = html || '<p class="text-sm text-slate-400 text-center py-8">No process data</p>';
            }
        }

        // Toggle always on top
        function toggleAlwaysOnTop() {
            isAlwaysOnTop = !isAlwaysOnTop;
            window.electronAPI.setAlwaysOnTop(isAlwaysOnTop);
            document.getElementById('pin-icon').className = isAlwaysOnTop 
                ? 'fas fa-thumbtack text-indigo-600' 
                : 'fas fa-thumbtack text-slate-600';
        }

        // Listen for server connection events from main process
        window.electronAPI.onServerConnected((serverId) => {
            currentServerId = serverId;
            refreshAllStats();
        });

        // Cleanup on unload
        window.addEventListener('beforeunload', () => {
            if (updateInterval) {
                clearInterval(updateInterval);
            }
        });

        // Start
        init();
    </script>
</body>
</html>
